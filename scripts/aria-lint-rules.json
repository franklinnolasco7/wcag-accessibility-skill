  "eslint_jsx_a11y": {
    "_usage": "Add to .eslintrc: { \"extends\": [\"plugin:jsx-a11y/recommended\"], \"rules\": { ... } }",
    "_install": "npm install --save-dev eslint-plugin-jsx-a11y",
    "recommended_rules": {
      "jsx-a11y/alt-text": "error",
      "jsx-a11y/anchor-has-content": "error",
      "jsx-a11y/anchor-is-valid": "error",
      "jsx-a11y/aria-activedescendant-has-tabindex": "error",
      "jsx-a11y/aria-props": "error",
      "jsx-a11y/aria-proptypes": "error",
      "jsx-a11y/aria-role": "error",
      "jsx-a11y/aria-unsupported-elements": "error",
      "jsx-a11y/autocomplete-valid": "error",
      "jsx-a11y/click-events-have-key-events": "error",
      "jsx-a11y/heading-has-content": "error",
      "jsx-a11y/html-has-lang": "error",
      "jsx-a11y/iframe-has-title": "error",
      "jsx-a11y/img-redundant-alt": "error",
      "jsx-a11y/interactive-supports-focus": "error",
      "jsx-a11y/label-has-associated-control": "error",
      "jsx-a11y/media-has-caption": "error",
      "jsx-a11y/mouse-events-have-key-events": "error",
      "jsx-a11y/no-access-key": "error",
      "jsx-a11y/no-aria-hidden-on-focusable": "error",
      "jsx-a11y/no-autofocus": "warn",
      "jsx-a11y/no-distracting-elements": "error",
      "jsx-a11y/no-interactive-element-to-noninteractive-role": "error",
      "jsx-a11y/no-noninteractive-element-interactions": "error",
      "jsx-a11y/no-noninteractive-element-to-interactive-role": "error",
      "jsx-a11y/no-noninteractive-tabindex": "error",
      "jsx-a11y/no-redundant-roles": "error",
      "jsx-a11y/no-static-element-interactions": "error",
      "jsx-a11y/prefer-tag-over-role": "warn",
      "jsx-a11y/role-has-required-aria-props": "error",
      "jsx-a11y/role-supports-aria-props": "error",
      "jsx-a11y/scope": "error",
      "jsx-a11y/tabindex-no-positive": "error"
    }
  },
  "wcag_criterion_mapping": {
    "_comment": "Maps axe rule IDs to WCAG 2.2 success criteria for triage and VPAT documentation.",
    "aria-allowed-attr": "4.1.2",
    "aria-hidden-focus": "1.3.1, 4.1.2",
    "aria-required-attr": "4.1.2",
    "aria-required-children": "1.3.1",
    "aria-required-parent": "1.3.1",
    "aria-roles": "4.1.2",
    "aria-valid-attr": "4.1.2",
    "aria-valid-attr-value": "4.1.2",
    "button-name": "4.1.2",
    "color-contrast": "1.4.3",
    "document-title": "2.4.2",
    "duplicate-id-aria": "4.1.1",
    "form-field-multiple-labels": "1.3.1",
    "frame-title": "2.4.1, 4.1.2",
    "heading-order": "1.3.1",
    "html-has-lang": "3.1.1",
    "image-alt": "1.1.1",
    "label": "1.3.1, 4.1.2",
    "landmark-one-main": "1.3.1",
    "link-name": "2.4.4, 4.1.2",
    "list": "1.3.1",
    "meta-refresh": "2.2.1, 2.2.4, 3.2.5",
    "meta-viewport": "1.4.4",
    "nested-interactive": "4.1.2",
    "no-autoplay-audio": "1.4.2",
    "server-side-image-map": "2.1.1",
    "skip-link": "2.4.1",
    "tabindex": "2.4.3",
    "table-duplicate-name": "1.3.1",
    "target-size": "2.5.8",
    "td-headers-attr": "1.3.1",
    "th-has-data-cells": "1.3.1",
    "valid-lang": "3.1.2"
  },
  "severity_levels": {
    "_comment": "Severity triage model. Critical blocks AT entirely; lower tiers reduce usability without blocking task completion.",
    "critical": {
      "description": "Blocks assistive technology users completely",
      "examples": [
        "Keyboard trap \u2014 user cannot navigate past element",
        "aria-hidden on focusable element \u2014 screen reader cannot access",
        "Missing form labels \u2014 screen reader users cannot complete form",
        "Missing alt text on functional images (links, buttons)"
      ]
    },
    "serious": {
      "description": "Significantly impairs access for some users",
      "examples": [
        "Color contrast failure on body text",
        "Missing page heading structure",
        "Interactive element not keyboard accessible",
        "Missing ARIA required attributes on custom widgets"
      ]
    },
    "moderate": {
      "description": "Causes confusion or reduced usability",
      "examples": [
        "Heading order skips levels",
        "Duplicate ID values",
        "Non-descriptive link text (click here, read more)",
        "Missing iframe title"
      ]
    },
    "minor": {
      "description": "Best practice; affects experience but not blocking",
      "examples": [
        "Redundant alt text duplicating adjacent text",
        "tabindex values > 0",
        "Missing lang attribute on specific content blocks"
      ]
    }
  }
}